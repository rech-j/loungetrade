# Django
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_SETTINGS_MODULE=config.settings.development

# Database
DB_NAME=loungecoin
DB_USER=loungecoin
DB_PASSWORD=loungecoin
DB_HOST=localhost
DB_PORT=5432

# Use SQLite for development without PostgreSQL
USE_SQLITE=false

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Production
ALLOWED_HOSTS=loungecoin.trade,www.loungecoin.trade,167.71.167.171
# Set to a random secret path to obscure the admin panel from bots
DJANGO_ADMIN_URL=admin/
# File path for production security logs (directory must exist and be writable)
DJANGO_LOG_FILE=/var/log/loungecoin/django.log

# Email (production only - dev uses console backend)
# Uses Brevo transactional API via django-anymail (HTTPS, no SMTP port needed).
# BREVO_API_KEY: Brevo dashboard → API Keys → Generate a new API key
# The DEFAULT_FROM_EMAIL sender domain MUST be verified in Brevo:
#   Brevo dashboard → Senders & IPs → Domains → add loungecoin.trade
#   then add the provided DKIM/SPF/DMARC DNS records at your domain registrar.
BREVO_API_KEY=
DEFAULT_FROM_EMAIL=noreply@loungecoin.trade
